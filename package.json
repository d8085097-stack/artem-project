{
  "name": "artem-project",
  "private": true,
  "workspaces": [
    "vinyl-store",
    "vinyl-store/landing-vinyl"
  ],
  "scripts": {
    "dev:all": "concurrently --names \"SERVER,STORE,LANDING\" --prefix-colors \"yellow,cyan,magenta\" \"npm run server:dev -w vinyl-store\" \"npm run dev -w vinyl-store\" \"npm run dev:3002 -w landing\"",
    "dev": "npm run dev -w vinyl-store",
    "server": "npm run server -w vinyl-store",
    "server:dev": "npm run server:dev -w vinyl-store",
    "store": "npm run dev -w vinyl-store",
    "landing": "npm run dev:3002 -w landing",
    "build": "npm run build -w vinyl-store"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}